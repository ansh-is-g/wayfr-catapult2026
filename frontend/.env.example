# Copy to `.env.local` in this folder for local development.
#
# The Next.js app does not call Modal directly. Only the Python backend needs
# MODAL_TOKEN_ID / MODAL_TOKEN_SECRET (see backend/.env.example).

# Local API (default if unset in code)
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# Supabase (public anon key is safe for the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Service role key — server-only, never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=

NEXT_PUBLIC_MAPBOX_TOKEN=
NEXT_PUBLIC_WORLD_APP_ID=

# When the FastAPI app is hosted on Modal, use HTTPS / WSS to that host, e.g.:
# NEXT_PUBLIC_API_URL=https://your-workspace--fastapi-app.modal.run
# NEXT_PUBLIC_WS_URL=wss://your-workspace--fastapi-app.modal.run
