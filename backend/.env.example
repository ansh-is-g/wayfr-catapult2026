# Copy to `.env` in this folder and fill in values. Never commit `.env`.
# Loaded via core/config.py from this directory regardless of process cwd (e.g. uvicorn from repo root).
#
# ── Modal API tokens (home setup GPU: reconstruction, annotation, HLoc)
# If your Modal credentials file looks like:
#   [workspace-or-profile]
#   token_id = "ak-..."
#   token_secret = "as-..."
#   active = true
# then set the env vars below — `active` is only for Modal’s own config, not for this app.
# You can also run `modal setup` once; the Python SDK will use stored credentials instead.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# Home setup requires these Modal apps to exist in YOUR workspace (environment "main").
# From the repo root, with the same Modal account as MODAL_TOKEN_* above:
#
#   modal deploy backend/pipelines/reconstruction/app.py
#   modal deploy backend/pipelines/video-annotator-mvp/modal_app_gsam2.py
#   modal deploy backend/pipelines/hloc_localization/backend/app.py
#
# First deploy can take a long time (image build + model download). If you skip one,
# the matching step will fail with "App '…' not found".
#
# Optional: override Modal app/function names (defaults match core/config.py)
# MODAL_RECONSTRUCT_APP=scene-reconstructor
# MODAL_RECONSTRUCT_FN=predict_video
# MODAL_ANNOTATOR_APP=video-annotator-gsam2
# MODAL_ANNOTATOR_FN=track_objects
# MODAL_HLOC_APP=hloc-localization
# MODAL_HLOC_BUILD_FN=build_reference
# MODAL_HLOC_LOCALIZE_FN=localize_frame

# ── Vision / LLM
RCAC_ENDPOINT_URL=
RCAC_API_KEY=
RCAC_TIMEOUT_MS=500

# RCAC GenAI — OpenAI-compatible API hosted at Purdue RCAC.
# Used for persona detection (streaming) and annotation plan generation.
# Also add these (without NEXT_PUBLIC_ prefix) to frontend/.env.local so the
# Next.js API routes (/api/personas/*) can call GenAI server-side.
GENAI_BASE_URL=https://genai.rcac.purdue.edu/api
GENAI_API_KEY=
GENAI_MODEL=llama4:latest

GEMINI_API_KEY=
GOOGLE_CLOUD_API_KEY=

# ── 3D / depth
SCENE3D_WINDOW_FRAMES=10
SCENE3D_VOXEL_M=0.05
REPLICATE_API_TOKEN=

# ── TTS
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=f0377496-2708-4cc9-b2f8-1b7fdb5e1a2a
CARTESIA_MODEL_ID=sonic-2

# ── Database (Supabase)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# ── Cache (Upstash Redis) — use either pair
UPSTASH_REDIS_URL=
UPSTASH_REDIS_TOKEN=
# UPSTASH_REDIS_REST_URL=
# UPSTASH_REDIS_REST_TOKEN=

# ── Auth / World ID
JWT_SECRET=dev-secret-change-in-prod
WORLD_APP_ID=

# ── Tunables (optional)
FRAME_RATE_FPS=5
SCENE_DESCRIPTION_INTERVAL_S=3.0
NARRATION_DEDUP_WINDOW_S=5.0
HAZARD_PROXIMITY_METERS=100.0
HAZARD_CACHE_TTL_S=60
